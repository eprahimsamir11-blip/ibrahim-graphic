# Environment Variables Template
# Copy this file to .env.local and fill in your values

# ================== DATABASE ==================
DATABASE_URL=postgresql://user:password@localhost:5432/ibrahim_graphic
# or for MongoDB:
# DATABASE_URL=mongodb://user:password@localhost:27017/ibrahim_graphic

# ================== NEXTAUTH ==================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_secret_key_here_change_in_production

# ================== APP ==================
NEXT_PUBLIC_APP_NAME=Ibrahim Graphic
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_DESCRIPTION=منصة إدارة مشاريع التصميم الجرافيكي

# ================== EMAIL ==================
# Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@ibrahim-graphic.com
EMAIL_FROM_NAME=Ibrahim Graphic

# Or use SendGrid
# SENDGRID_API_KEY=your_sendgrid_api_key

# ================== CLOUDINARY ==================
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ================== JWT ==================
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRATION=7d

# ================== PAYMENT (Optional) ==================
# Stripe
STRIPE_PUBLIC_KEY=pk_test_xxxx
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# ================== LOGGING ==================
LOG_LEVEL=info

# ================== CORS ==================
NEXT_PUBLIC_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ================== REDIS (Optional) ==================
REDIS_URL=redis://localhost:6379

# ================== DEVELOPMENT ==================
NODE_ENV=development
